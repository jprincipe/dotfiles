# themes
theme = "nordic"
# theme = "kanagawa"
# background = "#2A2A37"
# theme = everforest-dark
selection-background = #88c0d0
selection-foreground = #2e3440
background-opacity = 0.95
background-blur-radius = 10
alpha-blending = linear-corrected

macos-icon = official

# font settings
# font-family = "MonoLisa Nerd Font"
# font-family = "Iosevka NF"
font-family = "Maple Mono NF"
font-size = 14
font-thicken = true
font-feature = calt
font-feature = cv01

# clipboard settings
copy-on-select = clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false
scrollback-limit = 10000000

# window settings
macos-non-native-fullscreen = true
macos-titlebar-style = hidden
macos-titlebar-proxy-icon = hidden
macos-window-buttons = hidden
window-save-state = always
window-colorspace = "display-p3"
window-inherit-font-size = false
window-padding-x = 10
window-title-font-family = "Maple Mono NF"
mouse-hide-while-typing = true

# quick terminal
# quick-terminal-position = center
# quick-terminal-size = 75%,75%
# quick-terminal-animation-duration = 0
# quick-terminal-autohide = false

# keybinds
macos-option-as-alt = true
# keybind = global:super+/=toggle_quick_terminal
keybind = shift+enter=text:\n

# use dev builds
# auto-update-channel = tip

# cursor settings
cursor-style = block
cursor-color = #ffff00
cursor-opacity = 1.0
cursor-invert-fg-bg = false

# shaders
custom-shader-animation = always
custom-shader=./shaders/ripple_cursor.glsl
custom-shader=./shaders/cursor_warp.glsl
# custom-shader=./shaders/cursor_smear_fade.glsl
# custom-shader=./shaders/cursor_blaze.glsl
# custom-shader=./shaders/cursor_blaze_tapered.glsl
# custom-shader=./shaders/cursor_smear.glsl

